# =============================================
# Interview-Master — Environment Variables
# =============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in real values in .env
# 3. NEVER commit the actual .env file to Git
# =============================================

# Server Configuration
PORT=3000

# MongoDB Atlas Connection
# Get this from: cloud.mongodb.com → Clusters → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/interview-tracker?retryWrites=true&w=majority

# JWT Authentication Secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters long — NEVER use a short or guessable string
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-cryptographically-random

# ==============================================
# Add future environment variables below
# ==============================================

# STRIPE_SECRET_KEY=sk_test_...           # Stripe payment key (from dashboard.stripe.com)
# CLOUDINARY_URL=cloudinary://...         # File upload service
# SENDGRID_API_KEY=SG....                 # Email service
# REDIS_URL=redis://localhost:6379        # Cache/session store
# NODE_ENV=development                    # development | production | test
